#!/usr/bin/env bash
#
# walrus - PostgreSQL backup buddy for indie hackers
# https://github.com/LayFz/walrus
#
# Usage: walrus <command> [options]
# Run 'walrus help' for available commands.

set -euo pipefail

# ─── Resolve install location ────────────────────────────

# walrus can run from source (development) or from /usr/local/bin (installed).
# Libs are co-located in source, or under /opt/walrus/lib when installed.

_walrus_resolve_root() {
  local self_path
  self_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  local self_dir
  self_dir="$(cd "$(dirname "$self_path")" && pwd)"

  # Source tree: ./lib/ exists next to the walrus script
  if [[ -d "${self_dir}/lib" ]]; then
    echo "$self_dir"
    return
  fi

  # Installed: libs are in /opt/walrus/lib
  if [[ -d "/opt/walrus/lib" ]]; then
    echo "/opt/walrus"
    return
  fi

  echo >&2 "walrus: 找不到 lib 目录，请重新安装: walrus help"
  exit 1
}

readonly WALRUS_ROOT="$(_walrus_resolve_root)"

# ─── Load modules ────────────────────────────────────────

# Order matters: constants first, then colors, then logger (uses colors),
# then cleanup (uses logger), then everything else.

# shellcheck source=lib/constants.sh
source "${WALRUS_ROOT}/lib/constants.sh"
# shellcheck source=lib/colors.sh
source "${WALRUS_ROOT}/lib/colors.sh"
# shellcheck source=lib/logger.sh
source "${WALRUS_ROOT}/lib/logger.sh"
# shellcheck source=lib/cleanup.sh
source "${WALRUS_ROOT}/lib/cleanup.sh"
# shellcheck source=lib/utils.sh
source "${WALRUS_ROOT}/lib/utils.sh"
# shellcheck source=lib/lock.sh
source "${WALRUS_ROOT}/lib/lock.sh"
# shellcheck source=lib/project.sh
source "${WALRUS_ROOT}/lib/project.sh"
# shellcheck source=lib/r2.sh
source "${WALRUS_ROOT}/lib/r2.sh"
# shellcheck source=lib/pg.sh
source "${WALRUS_ROOT}/lib/pg.sh"

# Commands
# shellcheck source=commands/config.sh
source "${WALRUS_ROOT}/commands/config.sh"
# shellcheck source=commands/init.sh
source "${WALRUS_ROOT}/commands/init.sh"
# shellcheck source=commands/backup.sh
source "${WALRUS_ROOT}/commands/backup.sh"
# shellcheck source=commands/sync.sh
source "${WALRUS_ROOT}/commands/sync.sh"
# shellcheck source=commands/restore.sh
source "${WALRUS_ROOT}/commands/restore.sh"
# shellcheck source=commands/status.sh
source "${WALRUS_ROOT}/commands/status.sh"
# shellcheck source=commands/list.sh
source "${WALRUS_ROOT}/commands/list.sh"
# shellcheck source=commands/logs.sh
source "${WALRUS_ROOT}/commands/logs.sh"
# shellcheck source=commands/remove.sh
source "${WALRUS_ROOT}/commands/remove.sh"
# shellcheck source=commands/service.sh
source "${WALRUS_ROOT}/commands/service.sh"
# shellcheck source=commands/help.sh
source "${WALRUS_ROOT}/commands/help.sh"

# ─── Command dispatch ───────────────────────────────────

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    config)                cmd_config "$@" ;;
    init)                  cmd_init "$@" ;;
    backup)                cmd_backup "$@" ;;
    sync)                  cmd_sync "$@" ;;
    restore)               cmd_restore "$@" ;;
    status|st)             cmd_status "$@" ;;
    list|ls)               cmd_list "$@" ;;
    logs|log)              cmd_logs "$@" ;;
    service|svc)           cmd_service "$@" ;;
    remove|rm)             cmd_remove "$@" ;;
    help|-h|--help|"")     cmd_help ;;
    version|-v|--version)  echo "walrus v${WALRUS_VERSION}" ;;
    *)
      log_err "未知命令: ${command}"
      echo ""
      log_dim "运行 'walrus help' 查看可用命令"
      exit 1
      ;;
  esac
}

main "$@"
